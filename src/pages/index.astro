---
// Piano Studio Miami — Landing Page
// Framework: Astro | Styles: Tailwind CDN | Deploy: Cloudflare Pages
---

<!DOCTYPE html>
<html lang="pt-BR" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Estúdio de Piano Miami — Arte, Técnica e Excelência</title>
  <meta name="description" content="O estúdio de piano mais exclusivo de Miami. Aulas personalizadas para crianças, adultos e preparação para conservatório de nível mundial." />

  <!-- Tailwind CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            stone: {
              50:  '#fafaf9',
              100: '#f5f5f4',
              200: '#e7e5e4',
              300: '#d6d3d1',
              400: '#a8a29e',
              500: '#78716c',
              600: '#57534e',
              700: '#44403c',
              800: '#292524',
              900: '#1c1917',
              950: '#0c0a09',
            },
            amber: {
              200: '#fde68a',
              300: '#fcd34d',
              400: '#fbbf24',
              500: '#f59e0b',
            },
          },
          fontFamily: {
            serif:  ['Playfair Display', 'Georgia', 'serif'],
            sans:   ['Plus Jakarta Sans', 'system-ui', 'sans-serif'],
          },
          animation: {
            'fade-up':   'fadeUp 0.8s ease forwards',
            'fade-in':   'fadeIn 1s ease forwards',
            'float':     'float 6s ease-in-out infinite',
          },
          keyframes: {
            fadeUp:  { '0%': { opacity: '0', transform: 'translateY(30px)' }, '100%': { opacity: '1', transform: 'translateY(0)' } },
            fadeIn:  { '0%': { opacity: '0' }, '100%': { opacity: '1' } },
            float:   { '0%,100%': { transform: 'translateY(0)' }, '50%': { transform: 'translateY(-10px)' } },
          },
        },
      },
    }
  </script>

  <style>
    /* ── Base ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-family: 'Plus Jakarta Sans', sans-serif; background: #1c1917; color: #f5f5f4; }

    /* ── Scrollbar ── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #1c1917; }
    ::-webkit-scrollbar-thumb { background: #fbbf24; border-radius: 3px; }

    /* ── Selection ── */
    ::selection { background: rgba(251,191,36,.25); color: #fde68a; }

    /* ── Glassmorphism nav ── */
    .glass-nav {
      background: rgba(12, 10, 9, 0.55);
      backdrop-filter: blur(20px) saturate(1.4);
      -webkit-backdrop-filter: blur(20px) saturate(1.4);
      border-bottom: 1px solid rgba(251,191,36,.12);
    }

    /* ── Gold gradient text ── */
    .gold-text {
      background: linear-gradient(135deg, #fde68a 0%, #fbbf24 50%, #d97706 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Noise overlay ── */
    .noise::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      opacity: .5;
    }

    /* ── Fade-in on scroll ── */
    .reveal { opacity: 0; transform: translateY(28px); transition: opacity .75s ease, transform .75s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* ── Hero parallax bg ── */
    .hero-bg {
      background-image:
        linear-gradient(to bottom, rgba(12,10,9,.55) 0%, rgba(12,10,9,.8) 60%, rgba(12,10,9,1) 100%),
        url('https://images.unsplash.com/photo-1520523839897-bd0b52f945a0?w=1920&q=80&auto=format&fit=crop');
      background-size: cover;
      background-position: center 30%;
      background-attachment: fixed;
    }

    /* ── Card glass ── */
    .card-glass {
      background: rgba(28, 25, 23, 0.6);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(251,191,36,.13);
    }

    /* ── Gold line ── */
    .gold-line {
      width: 48px; height: 2px;
      background: linear-gradient(90deg, #fbbf24, transparent);
      margin-bottom: 1.25rem;
    }

    /* ── Testimonial card ── */
    .test-card {
      background: linear-gradient(135deg, rgba(40,35,30,.8) 0%, rgba(28,25,23,.9) 100%);
      border: 1px solid rgba(251,191,36,.1);
    }

    /* ── Input focus ── */
    input:focus, textarea:focus, select:focus {
      outline: none;
      border-color: rgba(251,191,36,.6) !important;
      box-shadow: 0 0 0 3px rgba(251,191,36,.08);
    }

    /* ── CTA button ── */
    .btn-gold {
      background: linear-gradient(135deg, #fbbf24 0%, #d97706 100%);
      color: #0c0a09;
      font-weight: 600;
      letter-spacing: .03em;
      transition: transform .2s ease, box-shadow .2s ease, opacity .2s ease;
      box-shadow: 0 4px 20px rgba(251,191,36,.3);
    }
    .btn-gold:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(251,191,36,.45); opacity: .95; }

    .btn-outline {
      border: 1.5px solid rgba(251,191,36,.55);
      color: #fde68a;
      transition: background .25s ease, color .25s ease;
    }
    .btn-outline:hover { background: rgba(251,191,36,.1); }

    /* ── WhatsApp float ── */
    .wa-float {
      animation: float 6s ease-in-out infinite;
      box-shadow: 0 8px 32px rgba(37,211,102,.35);
    }
    .wa-float:hover { transform: scale(1.08) translateY(-4px); }

    /* ── Section divider ── */
    .section-divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(251,191,36,.25), transparent);
    }

    /* ── Mobile nav ── */
    #mobile-menu { max-height: 0; overflow: hidden; transition: max-height .4s ease; }
    #mobile-menu.open { max-height: 400px; }
  </style>
</head>

<body class="bg-stone-950 text-stone-100 font-sans antialiased">

  <!-- ═══════════════════════════════════════════
       NAVIGATION
  ═══════════════════════════════════════════ -->
  <nav class="glass-nav fixed top-0 left-0 right-0 z-50">
    <div class="max-w-7xl mx-auto px-5 md:px-10 h-16 flex items-center justify-between">

      <!-- Logo -->
      <a href="#" class="flex items-center gap-2.5 group">
        <div class="w-7 h-7 rounded-full border border-amber-400/60 flex items-center justify-center">
          <div class="w-3 h-3 rounded-full bg-amber-400/80 group-hover:bg-amber-300 transition-colors"></div>
        </div>
        <span class="font-serif text-lg tracking-wide text-stone-100">
          Estúdio <span class="gold-text">Miami</span>
        </span>
      </a>

      <!-- Desktop links -->
      <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-stone-400">
        {['Serviços','Método','Depoimentos','Contato'].map(item => (
          <li>
            <a href={`#${item.toLowerCase()}`}
               class="hover:text-amber-300 transition-colors duration-200 tracking-wide">
              {item}
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA desktop -->
      <a href="#contato"
         class="hidden md:inline-flex btn-gold px-5 py-2 rounded-full text-sm">
        Agendar Aula
      </a>

      <!-- Hamburger -->
      <button id="hamburger" class="md:hidden text-stone-300 hover:text-amber-300 transition-colors" aria-label="Menu">
        <svg id="icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="md:hidden border-t border-stone-800/60">
      <ul class="px-5 py-4 flex flex-col gap-4 text-sm font-medium text-stone-400">
        {['Serviços','Método','Depoimentos','Contato'].map(item => (
          <li>
            <a href={`#${item.toLowerCase()}`}
               class="mobile-link hover:text-amber-300 transition-colors block py-1">{item}</a>
          </li>
        ))}
        <li>
          <a href="#contato" class="btn-gold inline-block px-5 py-2 rounded-full text-sm mt-1">
            Agendar Aula
          </a>
        </li>
      </ul>
    </div>
  </nav>


  <!-- ═══════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════ -->
  <section id="hero" class="hero-bg noise relative min-h-screen flex items-center pt-16">
    <div class="max-w-7xl mx-auto px-5 md:px-10 w-full py-28 md:py-40">

      <div class="max-w-3xl">
        <!-- Eyebrow -->
        <p class="text-amber-400/80 text-xs font-semibold tracking-[0.25em] uppercase mb-6 animate-fade-in">
          Miami · Piano de Alto Padrão
        </p>

        <!-- Headline -->
        <h1 class="font-serif text-4xl sm:text-6xl md:text-7xl leading-[1.08] tracking-tight mb-6"
            style="animation: fadeUp .9s .15s ease both;">
          Onde a música<br/>
          <em class="gold-text not-italic">encontra a excelência.</em>
        </h1>

        <!-- Subline -->
        <p class="text-stone-400 text-base md:text-lg leading-relaxed max-w-xl mb-10 font-light"
           style="animation: fadeUp .9s .3s ease both;">
          Um estúdio único em Miami, dedicado a revelar o verdadeiro potencial musical
          de cada aluno — da primeira nota ao palco de um conservatório internacional.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4"
             style="animation: fadeUp .9s .45s ease both;">
          <a href="#contato"
             class="btn-gold px-8 py-3.5 rounded-full text-sm text-center">
            Agendar Aula de Teste →
          </a>
          <a href="#método"
             class="btn-outline px-8 py-3.5 rounded-full text-sm text-center">
            Conhecer o Método
          </a>
        </div>

        <!-- Stats -->
        <div class="flex gap-10 mt-16" style="animation: fadeUp .9s .6s ease both;">
          {[['15+','Anos de experiência'],['300+','Alunos formados'],['12','Países representados']].map(([n,l]) => (
            <div>
              <p class="font-serif text-2xl md:text-3xl gold-text">{n}</p>
              <p class="text-stone-500 text-xs mt-1 leading-tight">{l}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40">
        <span class="text-stone-500 text-xs tracking-widest uppercase">scroll</span>
        <div class="w-px h-8 bg-gradient-to-b from-amber-400/60 to-transparent"></div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       SERVIÇOS
  ═══════════════════════════════════════════ -->
  <section id="serviços" class="py-28 px-5 md:px-10 bg-stone-950">
    <div class="max-w-7xl mx-auto">

      <!-- Header -->
      <div class="mb-16 reveal">
        <div class="gold-line"></div>
        <h2 class="font-serif text-3xl md:text-5xl mb-4">Nossos Programas</h2>
        <p class="text-stone-400 max-w-xl text-sm md:text-base leading-relaxed">
          Cada aluno é único. Por isso, desenvolvemos trilhas personalizadas que
          respeitam o tempo, os sonhos e o talento de cada um.
        </p>
      </div>

      <!-- Cards -->
      <div class="grid md:grid-cols-3 gap-6">

        <!-- Card 1 — Crianças -->
        <div class="reveal card-glass rounded-2xl overflow-hidden group hover:-translate-y-1.5 transition-transform duration-300">
          <div class="relative h-52 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1503676382389-4809596d5290?w=700&q=80&auto=format&fit=crop"
                 alt="Aulas para crianças"
                 class="w-full h-full object-cover opacity-60 group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-stone-900 via-stone-900/40 to-transparent"></div>
            <span class="absolute top-4 left-4 text-xs font-semibold tracking-widest text-amber-400 uppercase bg-stone-950/70 px-3 py-1 rounded-full border border-amber-400/20">
              4–12 anos
            </span>
          </div>
          <div class="p-7">
            <h3 class="font-serif text-xl mb-3 text-stone-50">Primeiros Acordes</h3>
            <p class="text-stone-400 text-sm leading-relaxed mb-6">
              Metodologia lúdica e sensorial que desperta o amor pela música enquanto
              desenvolve coordenação motora, disciplina e criatividade nas crianças.
            </p>
            <div class="flex flex-col gap-2 text-xs text-stone-500 mb-6">
              {['Aulas de 30–45 min, adaptadas à idade','Material didático exclusivo','Recitais semestrais para família'].map(f => (
                <div class="flex items-center gap-2">
                  <span class="text-amber-400">◆</span>{f}
                </div>
              ))}
            </div>
            <a href="#contato" class="btn-outline text-xs px-5 py-2 rounded-full inline-block">
              Saber mais
            </a>
          </div>
        </div>

        <!-- Card 2 — Adultos (destaque) -->
        <div class="reveal card-glass rounded-2xl overflow-hidden group hover:-translate-y-1.5 transition-transform duration-300 border-amber-400/25 relative md:-mt-4 md:mb-4 shadow-2xl shadow-amber-900/20">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-amber-400 via-amber-300 to-amber-500 rounded-t-2xl"></div>
          <div class="relative h-52 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1571974599782-87624638275e?w=700&q=80&auto=format&fit=crop"
                 alt="Aulas para adultos"
                 class="w-full h-full object-cover opacity-55 group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-stone-900 via-stone-900/40 to-transparent"></div>
            <span class="absolute top-4 left-4 text-xs font-semibold tracking-widest text-stone-900 uppercase bg-amber-400 px-3 py-1 rounded-full">
              ✦ Mais Popular
            </span>
          </div>
          <div class="p-7">
            <h3 class="font-serif text-xl mb-3 text-stone-50">Piano para Adultos</h3>
            <p class="text-stone-400 text-sm leading-relaxed mb-6">
              Nunca é tarde para começar. Um programa flexível e respeitoso ao ritmo
              do adulto, do iniciante ao nível avançado, com repertório personalizado.
            </p>
            <div class="flex flex-col gap-2 text-xs text-stone-500 mb-6">
              {['Horários flexíveis para profissionais','Do clássico ao jazz contemporâneo','Progresso mensurável e rápido'].map(f => (
                <div class="flex items-center gap-2">
                  <span class="text-amber-400">◆</span>{f}
                </div>
              ))}
            </div>
            <a href="#contato" class="btn-gold text-xs px-5 py-2 rounded-full inline-block">
              Agendar Aula Grátis
            </a>
          </div>
        </div>

        <!-- Card 3 — Conservatório -->
        <div class="reveal card-glass rounded-2xl overflow-hidden group hover:-translate-y-1.5 transition-transform duration-300">
          <div class="relative h-52 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1507838153414-b4b713384a76?w=700&q=80&auto=format&fit=crop"
                 alt="Preparação para conservatório"
                 class="w-full h-full object-cover opacity-55 group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-stone-900 via-stone-900/40 to-transparent"></div>
            <span class="absolute top-4 left-4 text-xs font-semibold tracking-widest text-amber-400 uppercase bg-stone-950/70 px-3 py-1 rounded-full border border-amber-400/20">
              Avançado
            </span>
          </div>
          <div class="p-7">
            <h3 class="font-serif text-xl mb-3 text-stone-50">Elite Conservatório</h3>
            <p class="text-stone-400 text-sm leading-relaxed mb-6">
              Preparação intensiva para audições nas melhores instituições do mundo,
              com foco em técnica avançada, interpretação e performance de palco.
            </p>
            <div class="flex flex-col gap-2 text-xs text-stone-500 mb-6">
              {['Ensaios com pianistas internacionais','Masterclasses e workshops exclusivos','Taxa de aprovação de 94% nas audições'].map(f => (
                <div class="flex items-center gap-2">
                  <span class="text-amber-400">◆</span>{f}
                </div>
              ))}
            </div>
            <a href="#contato" class="btn-outline text-xs px-5 py-2 rounded-full inline-block">
              Saber mais
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <div class="section-divider"></div>


  <!-- ═══════════════════════════════════════════
       SOBRE O MÉTODO
  ═══════════════════════════════════════════ -->
  <section id="método" class="py-28 px-5 md:px-10 bg-stone-900/40">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 md:gap-20 items-center">

      <!-- Image col -->
      <div class="reveal relative order-2 md:order-1">
        <div class="relative rounded-2xl overflow-hidden aspect-[4/5] max-w-sm mx-auto md:mx-0">
          <img src="https://images.unsplash.com/photo-1466428996289-fb355538da1b?w=800&q=80&auto=format&fit=crop"
               alt="Professora ao piano"
               class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-stone-950/70 via-transparent to-transparent"></div>
        </div>
        <!-- Floating badge -->
        <div class="absolute -bottom-5 -right-2 md:right-10 card-glass rounded-xl px-5 py-4 flex items-center gap-3 shadow-xl">
          <div class="text-3xl font-serif gold-text leading-none">94%</div>
          <div class="text-xs text-stone-400 leading-tight">Aprovação em<br/>conservatórios</div>
        </div>
        <!-- Decorative line -->
        <div class="absolute -top-6 -left-6 w-24 h-24 border border-amber-400/15 rounded-full hidden md:block"></div>
        <div class="absolute -top-3 -left-3 w-12 h-12 border border-amber-400/25 rounded-full hidden md:block"></div>
      </div>

      <!-- Text col -->
      <div class="reveal order-1 md:order-2">
        <div class="gold-line"></div>
        <h2 class="font-serif text-3xl md:text-5xl mb-6 leading-tight">
          Um método construído<br/>
          <em class="gold-text not-italic">para resultados reais.</em>
        </h2>
        <p class="text-stone-400 text-sm md:text-base leading-relaxed mb-5">
          Fundado pela Profa. Adriana Voss — formada no Conservatório Real de Bruxelas e
          ex-concertista em 18 países — o Estúdio de Piano Miami une a rigor da tradição
          europeia à sensibilidade do ensino moderno.
        </p>
        <p class="text-stone-400 text-sm md:text-base leading-relaxed mb-8">
          Nosso método proprietário <span class="text-amber-300 font-medium">Resonance Path™</span> integra
          neurociência musical, pedagogia Suzuki e técnica de performance para criar
          músicos completos — não apenas intérpretes.
        </p>

        <div class="grid grid-cols-2 gap-4 mb-8">
          {[['Turmas reduzidas','Máximo 1 aluno por sessão individual'],['Avaliações mensais','Feedback estruturado e relatórios'],['Piano Steinway','Instrumentos de concerto no estúdio'],['Localização','Brickell, Miami — acesso fácil']].map(([t,d]) => (
            <div class="bg-stone-800/40 rounded-xl p-4 border border-stone-700/30">
              <p class="text-amber-400 text-xs font-semibold mb-1">{t}</p>
              <p class="text-stone-400 text-xs leading-snug">{d}</p>
            </div>
          ))}
        </div>

        <a href="#contato" class="btn-gold px-8 py-3 rounded-full text-sm inline-block">
          Conhecer o Estúdio
        </a>
      </div>

    </div>
  </section>

  <div class="section-divider"></div>


  <!-- ═══════════════════════════════════════════
       DEPOIMENTOS
  ═══════════════════════════════════════════ -->
  <section id="depoimentos" class="py-28 px-5 md:px-10 bg-stone-950">
    <div class="max-w-7xl mx-auto">

      <div class="text-center mb-16 reveal">
        <div class="gold-line mx-auto"></div>
        <h2 class="font-serif text-3xl md:text-5xl mb-4">O que dizem sobre nós</h2>
        <p class="text-stone-400 text-sm md:text-base max-w-md mx-auto">
          Histórias reais de alunos e famílias que transformaram sua relação com a música.
        </p>
      </div>

      <!-- Testimonials grid -->
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { name:'Sofia Andrade', role:'Aluna — 9 anos', text:'Em apenas 6 meses, minha filha já toca duas peças de Beethoven. A professora Adriana tem um dom para ensinar crianças com paciência e carinho infinito.', avatar:'S', stars:5 },
          { name:'Marcus Chen', role:'Aluno adulto', text:'Comecei do zero aos 38 anos. Achei que seria impossível, mas o método do estúdio é tão claro e motivador que em 1 ano já me apresentei em recital. Surreal.', avatar:'M', stars:5 },
          { name:'Isabella Torres', role:'Aprovada no Juilliard', text:'O programa Elite Conservatório foi decisivo na minha aprovação ao Juilliard. Os ensaios de performance e o feedback técnico são de nível internacional.', avatar:'I', stars:5 },
        ].map(({ name, role, text, avatar, stars }) => (
          <div class="reveal test-card rounded-2xl p-7 hover:-translate-y-1 transition-transform duration-300">
            <div class="flex items-center gap-1 mb-5">
              {Array(stars).fill(0).map(() => <span class="text-amber-400 text-sm">★</span>)}
            </div>
            <p class="text-stone-300 text-sm leading-relaxed mb-6 italic">"{text}"</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center text-stone-900 font-bold text-sm flex-shrink-0">
                {avatar}
              </div>
              <div>
                <p class="text-stone-100 text-sm font-medium">{name}</p>
                <p class="text-stone-500 text-xs">{role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Press strip -->
      <div class="mt-16 reveal">
        <p class="text-center text-stone-600 text-xs tracking-widest uppercase mb-8">Mencionado em</p>
        <div class="flex flex-wrap justify-center gap-8 md:gap-16 items-center opacity-30">
          {['Miami Herald','El Nuevo Herald','Classical Music Mag','Florida Arts Today','Culture Trip'].map(p => (
            <span class="text-stone-300 text-sm font-serif italic">{p}</span>
          ))}
        </div>
      </div>

    </div>
  </section>

  <div class="section-divider"></div>


  <!-- ═══════════════════════════════════════════
       FORMULÁRIO DE CONTATO
  ═══════════════════════════════════════════ -->
  <section id="contato" class="py-28 px-5 md:px-10 bg-stone-900/50 relative overflow-hidden">
    <!-- BG decoration -->
    <div class="absolute -top-32 -right-32 w-96 h-96 rounded-full bg-amber-500/5 blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-32 -left-32 w-96 h-96 rounded-full bg-amber-500/5 blur-3xl pointer-events-none"></div>

    <div class="max-w-2xl mx-auto relative">

      <div class="text-center mb-12 reveal">
        <div class="gold-line mx-auto"></div>
        <h2 class="font-serif text-3xl md:text-5xl mb-4">Agende sua Aula de Teste</h2>
        <p class="text-stone-400 text-sm md:text-base">
          Gratuita e sem compromisso. Conheça o estúdio e experimente o método em pessoa.
        </p>
      </div>

      <form id="contact-form" class="reveal card-glass rounded-3xl p-8 md:p-12 space-y-5" novalidate>

        <!-- Row 1 -->
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-xs font-medium text-stone-400 mb-2 tracking-wide" for="name">Nome completo</label>
            <input type="text" id="name" name="name" required placeholder="Seu nome"
                   class="w-full bg-stone-800/60 border border-stone-700/60 rounded-xl px-4 py-3 text-stone-100 text-sm placeholder:text-stone-600 transition-all duration-200" />
          </div>
          <div>
            <label class="block text-xs font-medium text-stone-400 mb-2 tracking-wide" for="email">E-mail</label>
            <input type="email" id="email" name="email" required placeholder="seu@email.com"
                   class="w-full bg-stone-800/60 border border-stone-700/60 rounded-xl px-4 py-3 text-stone-100 text-sm placeholder:text-stone-600 transition-all duration-200" />
          </div>
        </div>

        <!-- Row 2 -->
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-xs font-medium text-stone-400 mb-2 tracking-wide" for="phone">Telefone / WhatsApp</label>
            <input type="tel" id="phone" name="phone" placeholder="+1 (305) 000-0000"
                   class="w-full bg-stone-800/60 border border-stone-700/60 rounded-xl px-4 py-3 text-stone-100 text-sm placeholder:text-stone-600 transition-all duration-200" />
          </div>
          <div>
            <label class="block text-xs font-medium text-stone-400 mb-2 tracking-wide" for="interest">Interesse</label>
            <select id="interest" name="interest"
                    class="w-full bg-stone-800/60 border border-stone-700/60 rounded-xl px-4 py-3 text-stone-100 text-sm transition-all duration-200 appearance-none cursor-pointer">
              <option value="" disabled selected class="text-stone-600">Selecione um programa</option>
              <option value="criancas">Primeiros Acordes — Crianças</option>
              <option value="adultos">Piano para Adultos</option>
              <option value="conservatorio">Elite Conservatório</option>
              <option value="outro">Outro / Tenho dúvidas</option>
            </select>
          </div>
        </div>

        <!-- Message -->
        <div>
          <label class="block text-xs font-medium text-stone-400 mb-2 tracking-wide" for="message">Mensagem (opcional)</label>
          <textarea id="message" name="message" rows="4" placeholder="Conte-nos sobre sua experiência musical ou o que espera das aulas..."
                    class="w-full bg-stone-800/60 border border-stone-700/60 rounded-xl px-4 py-3 text-stone-100 text-sm placeholder:text-stone-600 transition-all duration-200 resize-none"></textarea>
        </div>

        <!-- Privacy note -->
        <p class="text-stone-600 text-xs">
          Suas informações são confidenciais e nunca serão compartilhadas com terceiros.
        </p>

        <!-- Submit -->
        <button type="submit"
                class="btn-gold w-full py-4 rounded-xl text-sm font-semibold tracking-wide">
          Enviar solicitação →
        </button>

        <!-- Success message (hidden) -->
        <div id="form-success" class="hidden text-center py-4">
          <p class="text-amber-400 font-serif text-lg">✦ Mensagem recebida!</p>
          <p class="text-stone-400 text-sm mt-1">Entraremos em contato em até 24 horas.</p>
        </div>

      </form>

      <!-- Alternative contact -->
      <div class="reveal mt-10 grid sm:grid-cols-3 gap-4 text-center">
        {[
          { icon:'📍', label:'Endereço', val:'Brickell Ave, Miami, FL' },
          { icon:'📞', label:'Telefone', val:'+1 (305) 555-0190' },
          { icon:'🕐', label:'Horários', val:'Seg–Sáb, 8h–20h' },
        ].map(({ icon, label, val }) => (
          <div class="bg-stone-800/30 rounded-xl p-4 border border-stone-700/20">
            <div class="text-xl mb-1">{icon}</div>
            <p class="text-stone-500 text-xs mb-0.5">{label}</p>
            <p class="text-stone-300 text-xs font-medium">{val}</p>
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       FOOTER
  ═══════════════════════════════════════════ -->
  <footer class="bg-stone-950 border-t border-stone-800/60 py-10 px-5 md:px-10">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2.5">
        <div class="w-6 h-6 rounded-full border border-amber-400/40 flex items-center justify-center">
          <div class="w-2.5 h-2.5 rounded-full bg-amber-400/60"></div>
        </div>
        <span class="font-serif text-base text-stone-400">
          Estúdio <span class="gold-text">Miami</span>
        </span>
      </div>
      <p class="text-stone-600 text-xs">
        © {new Date().getFullYear()} Estúdio de Piano Miami. Todos os direitos reservados.
      </p>
      <div class="flex gap-5 text-stone-600 text-xs">
        <a href="#" class="hover:text-amber-400 transition-colors">Privacidade</a>
        <a href="#" class="hover:text-amber-400 transition-colors">Termos</a>
        <a href="#contato" class="hover:text-amber-400 transition-colors">Contato</a>
      </div>
    </div>
  </footer>


  <!-- ═══════════════════════════════════════════
       WHATSAPP FLOAT
  ═══════════════════════════════════════════ -->
  <a href="https://wa.me/13055550190?text=Olá!%20Tenho%20interesse%20em%20conhecer%20o%20Estúdio%20de%20Piano%20Miami."
     target="_blank" rel="noopener noreferrer"
     aria-label="Falar no WhatsApp"
     class="wa-float fixed bottom-6 right-6 z-50 w-14 h-14 rounded-full flex items-center justify-center bg-[#25D366] hover:bg-[#20bd5a] transition-colors duration-300">
    <svg viewBox="0 0 24 24" class="w-7 h-7 fill-white" xmlns="http://www.w3.org/2000/svg">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
      <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.553 4.116 1.522 5.845L.057 23.5a.5.5 0 0 0 .613.613l5.657-1.464A11.944 11.944 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.9a9.888 9.888 0 0 1-5.031-1.374l-.36-.214-3.732.965.99-3.631-.234-.373A9.856 9.856 0 0 1 2.1 12c0-5.459 4.441-9.9 9.9-9.9 5.459 0 9.9 4.441 9.9 9.9 0 5.459-4.441 9.9-9.9 9.9z"/>
    </svg>
  </a>


  <!-- ═══════════════════════════════════════════
       SCRIPTS
  ═══════════════════════════════════════════ -->
  <script>
    // ── Mobile nav ──
    const hamburger  = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconOpen   = document.getElementById('icon-open');
    const iconClose  = document.getElementById('icon-close');
    const mobileLinks = document.querySelectorAll('.mobile-link');

    function toggleMenu(forceClose = false) {
      const isOpen = mobileMenu.classList.contains('open');
      if (forceClose || isOpen) {
        mobileMenu.classList.remove('open');
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
      } else {
        mobileMenu.classList.add('open');
        iconOpen.classList.add('hidden');
        iconClose.classList.remove('hidden');
      }
    }
    hamburger.addEventListener('click', () => toggleMenu());
    mobileLinks.forEach(l => l.addEventListener('click', () => toggleMenu(true)));

    // ── Scroll reveal ──
    const revealEls = document.querySelectorAll('.reveal');
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach((e, i) => {
        if (e.isIntersecting) {
          setTimeout(() => e.target.classList.add('visible'), i * 80);
          revealObs.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });
    revealEls.forEach(el => revealObs.observe(el));

    // ── Navbar shrink on scroll ──
    const nav = document.querySelector('nav');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 60) {
        nav.style.borderBottomColor = 'rgba(251,191,36,.18)';
      } else {
        nav.style.borderBottomColor = 'rgba(251,191,36,.12)';
      }
    }, { passive: true });

    // ── Form submit ──
    const form = document.getElementById('contact-form');
    const success = document.getElementById('form-success');
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]');
      btn.textContent = 'Enviando…';
      btn.disabled = true;
      // Simula envio (conectar ao backend real aqui)
      setTimeout(() => {
        form.querySelectorAll('input, textarea, select').forEach(el => el.style.opacity = '.4');
        btn.style.display = 'none';
        success.classList.remove('hidden');
      }, 1500);
    });
  </script>

</body>
</html>
