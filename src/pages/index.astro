---
// index.astro - Versión Luxury para Piano Miami
const title = "Harmony Piano Studio | Clases de Piano en Miami";
---

<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;600&display=swap" rel="stylesheet">
		
		<script src="https://cdn.tailwindcss.com"></script>
		
		<style>
			:root {
				--primary: #d4a373; /* Dorado suave */
				--dark: #1c1917;    /* Piedra oscura */
			}
			body { 
				font-family: 'Plus Jakarta Sans', sans-serif; 
				background-color: #fdfcfb;
			}
			h1, h2, h3, .font-serif { 
				font-family: 'Playfair Display', serif; 
			}
			.glass {
				background: rgba(255, 255, 255, 0.7);
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				border: 1px solid rgba(255, 255, 255, 0.3);
			}
			.hero-gradient {
				background: linear-gradient(to bottom, rgba(28,25,23,0.8), rgba(28,25,23,0.4));
			}
		</style>
	</head>
	<body class="text-stone-800">

		<nav class="fixed w-full z-[100] px-6 py-4">
			<div class="max-w-7xl mx-auto flex justify-between items-center glass rounded-2xl px-8 py-4 shadow-xl">
				<div class="text-xl font-bold tracking-[0.2em] text-stone-900 uppercase">
					Piano<span class="text-[#d4a373]">Miami</span>
				</div>
				<div class="hidden md:flex space-x-10 text-[11px] font-bold uppercase tracking-[0.2em]">
					<a href="#inicio" class="hover:text-[#d4a373] transition-colors">Inicio</a>
					<a href="#metodo" class="hover:text-[#d4a373] transition-colors">El Método</a>
					<a href="#clases" class="hover:text-[#d4a373] transition-colors">Programas</a>
					<a href="#contacto" class="bg-stone-900 text-white px-6 py-3 rounded-full hover:bg-[#d4a373] transition-all duration-300">Reserva ahora</a>
				</div>
			</div>
		</nav>

		<section id="inicio" class="relative h-screen flex items-center justify-center overflow-hidden">
			<div class="absolute inset-0 z-0">
				<img 
					src="https://images.unsplash.com/photo-1552422535-c45813c61732?q=80&w=2070&auto=format&fit=crop" 
					class="w-full h-full object-cover scale-105" 
					alt="Piano"
				/>
				<div class="absolute inset-0 hero-gradient"></div>
			</div>

			<div class="relative z-10 text-center px-6 max-w-4xl">
				<span class="text-[#d4a373] uppercase tracking-[0.5em] text-xs font-bold mb-6 block animate-fade-in">Private Music Education</span>
				<h1 class="text-6xl md:text-8xl text-white mb-8 leading-[1.1]">
					Toca con <span class="italic">maestría.</span>
				</h1>
				<p class="text-stone-300 text-lg md:text-xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
					En el corazón de Miami, transformamos la técnica en arte. Clases exclusivas para mentes creativas.
				</p>
				<div class="flex flex-col md:flex-row gap-4 justify-center">
					<a href="#contacto" class="bg-[#d4a373] text-white px-12 py-5 rounded-full font-bold uppercase text-[10px] tracking-[0.2em] hover:bg-white hover:text-stone-900 transition-all shadow-2xl">
						Solicitar Audición
					</a>
				</div>
			</div>
			
			<div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
				<div class="w-[1px] h-16 bg-white/30"></div>
			</div>
		</section>

		<section id="metodo" class="py-32 px-6 bg-white">
			<div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-20 items-center">
				<div class="relative">
					<div class="absolute -top-10 -left-10 w-40 h-40 bg-[#d4a373]/10 rounded-full blur-3xl"></div>
					<img src="https://images.unsplash.com/photo-1594122230689-45899d9e6f69?q=80&w=2070&auto=format&fit=crop" class="rounded-3xl shadow-2xl relative z-10" alt="Education" />
				</div>
				<div>
					<h2 class="text-5xl mb-8 leading-tight italic">Un enfoque diseñado para la excelencia.</h2>
					<p class="text-stone-500 text-lg leading-relaxed mb-8">
						No solo enseñamos a leer partituras; cultivamos la sensibilidad musical. Nuestro estudio utiliza pianos de cola alemanes en un entorno diseñado para la concentración y la inspiración.
					</p>
					<div class="grid grid-cols-2 gap-8">
						<div>
							<h4 class="font-bold text-stone-900 mb-2 uppercase text-xs tracking-widest">Ubicación</h4>
							<p class="text-sm text-stone-500 italic">Brickell / Downtown Miami</p>
						</div>
						<div>
							<h4 class="font-bold text-stone-900 mb-2 uppercase text-xs tracking-widest">Instrumento</h4>
							<p class="text-sm text-stone-500 italic">Steinway & Sons Professional</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section id="clases" class="py-32 px-6 bg-[#f8f5f2]">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-20">
					<h2 class="text-5xl mb-4">Programas Exclusivos</h2>
					<div class="w-20 h-[2px] bg-[#d4a373] mx-auto"></div>
				</div>

				<div class="grid md:grid-cols-3 gap-8">
					<div class="bg-white p-12 rounded-[2rem] shadow-sm hover:shadow-2xl transition-all duration-500 group border border-stone-100">
						<div class="w-12 h-12 bg-stone-50 rounded-full flex items-center justify-center mb-8 group-hover:bg-[#d4a373] transition-colors">
							<span class="text-stone-400 group-hover:text-white text-xs">01</span>
						</div>
						<h3 class="text-2xl mb-4 italic font-bold">Iniciación Infantil</h3>
						<p class="text-stone-500 text-sm leading-relaxed mb-8">Desarrollo cognitivo y motriz a través del juego y la teoría musical básica.</p>
						<p class="text-[#d4a373] font-bold text-sm tracking-widest uppercase">$240 / Mes</p>
					</div>

					<div class="bg-stone-900 p-12 rounded-[2rem] shadow-2xl transition-all duration-500 transform md:-translate-y-4">
						<div class="w-12 h-12 bg-stone-800 rounded-full flex items-center justify-center mb-8">
							<span class="text-[#d4a373] text-xs font-bold italic">PRO</span>
						</div>
						<h3 class="text-2xl mb-4 italic font-bold text-white">Adult Performance</h3>
						<p class="text-stone-400 text-sm leading-relaxed mb-8">Repertorio clásico y moderno adaptado a tu ritmo. Perfeccionamiento técnico avanzado.</p>
						<p class="text-[#d4a373] font-bold text-sm tracking-widest uppercase">$320 / Mes</p>
					</div>

					<div class="bg-white p-12 rounded-[2rem] shadow-sm hover:shadow-2xl transition-all duration-500 group border border-stone-100">
						<div class="w-12 h-12 bg-stone-50 rounded-full flex items-center justify-center mb-8 group-hover:bg-[#d4a373] transition-colors">
							<span class="text-stone-400 group-hover:text-white text-xs">03</span>
						</div>
						<h3 class="text-2xl mb-4 italic font-bold">Intensivo Conservatorio</h3>
						<p class="text-stone-500 text-sm leading-relaxed mb-8">Preparación para exámenes oficiales y audiciones profesionales.</p>
						<p class="text-[#d4a373] font-bold text-sm tracking-widest uppercase">Consultar</p>
					</div>
				</div>
			</div>
		</section>

		<section id="contacto" class="py-32 bg-stone-900 text-white px-6">
			<div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-20">
				<div>
					<h2 class="text-6xl mb-8 leading-tight italic">Comienza tu viaje.</h2>
					<p class="text-stone-400 text-lg mb-12">Estamos en el área de Brickell. Envíanos tus datos para coordinar una clase de cortesía.</p>
					<div class="space-y-6">
						<p class="flex items-center text-stone-300">
							<span class="w-10 h-10 border border-stone-700 rounded-full flex items-center justify-center mr-4">📍</span>
							Miami, FL - Brickell District
						</p>
						<p class="flex items-center text-stone-300">
							<span class="w-10 h-10 border border-stone-700 rounded-full flex items-center justify-center mr-4">✉️</span>
							tania@pianomiami.com
						</p>
					</div>
				</div>
				
				<div class="bg-white/5 p-10 rounded-3xl backdrop-blur-md border border-white/10">
					<form class="space-y-6">
						<input type="text" placeholder="Nombre" class="w-full bg-transparent border-b border-stone-700 py-4 outline-none focus:border-[#d4a373] transition-colors text-white" />
						<input type="email" placeholder="Email" class="w-full bg-transparent border-b border-stone-700 py-4 outline-none focus:border-[#d4a373] transition-colors text-white" />
						<textarea placeholder="Cuéntanos tu interés..." class="w-full bg-transparent border-b border-stone-700 py-4 outline-none focus:border-[#d4a373] transition-colors text-white h-32"></textarea>
						<button class="w-full bg-[#d4a373] py-5 rounded-full font-bold uppercase text-[10px] tracking-[0.2em] hover:bg-white hover:text-stone-900 transition-all shadow-xl">
							Enviar Mensaje
						</button>
					</form>
				</div>
			</div>
		</section>

		<footer class="py-20 text-center bg-stone-900 border-t border-white/5">
			<p class="text-stone-600 text-[10px] uppercase tracking-[0.4em]">© 2026 Harmony Piano Studio | Miami, Florida</p>
		</footer>

	</body>
</html>