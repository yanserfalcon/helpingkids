---
// Piano Studio Miami — Landing Page Corregida
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Piano Studio Miami | Arte y Excelencia</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;600&display=swap" rel="stylesheet" />

  <style>
    /* Estilos de respaldo en caso de que el CDN tarde en cargar */
    body { 
      font-family: 'Plus Jakarta Sans', sans-serif; 
      background-color: #fafaf9; 
      margin: 0;
    }
    h1, h2, h3 { font-family: 'Playfair Display', serif; }
    
    .glass {
      background: rgba(255, 255, 255, 0.8);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
  </style>
</head>

<body class="text-stone-900 overflow-x-hidden">

  <a href="#" class="fixed bottom-6 right-6 z-[100] bg-[#25D366] text-white p-4 rounded-full shadow-2xl hover:scale-110 transition-transform">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.588-5.946 0-6.556 5.332-11.888 11.888-11.888 3.176 0 6.161 1.237 8.404 3.48s3.481 5.229 3.481 8.405c0 6.555-5.332 11.89-11.888 11.89-2.015 0-3.991-.511-5.741-1.486l-6.143 1.611zm6.103-4.494l.33.195c1.438.853 3.092 1.303 4.789 1.303 4.954 0 8.991-4.037 8.991-8.991 0-2.399-.933-4.655-2.63-6.353s-3.955-2.63-6.352-2.63c-4.954 0-8.991 4.037-8.991 8.991 0 1.776.52 3.514 1.502 5.025l.219.337-1.124 4.103 4.266-1.119zm10.444-6.381c-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.668.149-.198.297-.767.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414-.073-.124-.271-.198-.57-.347z"/></svg>
  </a>

  <nav class="fixed w-full z-[90] p-4 md:p-6">
    <div class="max-w-6xl mx-auto glass shadow-lg rounded-2xl p-4 flex justify-between items-center border border-white/20">
      <div class="font-bold tracking-tighter text-xl">PIANO<span class="text-amber-600">STUDIO</span></div>
      <div class="hidden md:flex space-x-8 text-xs font-bold uppercase tracking-widest">
        <a href="#clases" class="hover:text-amber-600 transition">Clases</a>
        <a href="#contacto" class="bg-stone-900 text-white px-6 py-2 rounded-full hover:bg-amber-600 transition">Contacto</a>
      </div>
    </div>
  </nav>

  <section class="h-screen relative flex items-center justify-center text-center px-6">
    <div class="absolute inset-0 z-0">
      <img src="https://images.unsplash.com/photo-1520527053377-4710dbf6c0eb?auto=format&fit=crop&q=80" class="w-full h-full object-cover" alt="Piano" />
      <div class="absolute inset-0 bg-stone-900/60"></div>
    </div>
    
    <div class="relative z-10 text-white max-w-3xl">
      <h1 class="text-5xl md:text-7xl mb-6">Música que inspira.</h1>
      <p class="text-lg md:text-xl text-stone-300 mb-10 font-light">Lecciones de piano de clase mundial en Miami para todas las edades.</p>
      <a href="#contacto" class="bg-amber-600 px-10 py-4 rounded-full font-bold uppercase tracking-widest text-xs hover:bg-white hover:text-stone-900 transition-all">Empezar hoy</a>
    </div>
  </section>

  <section id="clases" class="py-24 px-6 bg-white">
    <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-10">
      <div class="p-10 rounded-3xl bg-stone-50 border border-stone-100 hover:shadow-xl transition">
        <h3 class="text-2xl mb-4 italic">Niños</h3>
        <p class="text-stone-500 text-sm mb-6">Aprendizaje creativo y divertido para desarrollar el talento desde la infancia.</p>
        <span class="text-amber-600 font-bold">$240 / mes</span>
      </div>
      <div class="p-10 rounded-3xl bg-stone-900 text-white shadow-2xl">
        <h3 class="text-2xl mb-4 italic">Adultos</h3>
        <p class="text-stone-400 text-sm mb-6">Nunca es tarde para cumplir tu sueño de tocar el piano. Horarios flexibles.</p>
        <span class="text-amber-600 font-bold">$300 / mes</span>
      </div>
      <div class="p-10 rounded-3xl bg-stone-50 border border-stone-100 hover:shadow-xl transition">
        <h3 class="text-2xl mb-4 italic">Avanzado</h3>
        <p class="text-stone-500 text-sm mb-6">Técnica superior y preparación para audiciones y conservatorio.</p>
        <span class="text-amber-600 font-bold">Consultar</span>
      </div>
    </div>
  </section>

  <section id="contacto" class="py-24 px-6 bg-stone-900">
    <div class="max-w-2xl mx-auto text-center text-white">
      <h2 class="text-4xl mb-12 italic">Reserva tu audición</h2>
      <form action="#" class="space-y-4 text-left">
        <input type="text" placeholder="Nombre" class="w-full p-4 bg-white/10 border border-white/20 rounded-xl outline-none focus:border-amber-600 text-white" />
        <input type="email" placeholder="Email" class="w-full p-4 bg-white/10 border border-white/20 rounded-xl outline-none focus:border-amber-600 text-white" />
        <button class="w-full bg-amber-600 p-4 rounded-xl font-bold uppercase tracking-widest text-xs hover:bg-white hover:text-stone-900 transition-all">Enviar Mensaje</button>
      </form>
    </div>
  </section>

  <footer class="py-12 text-center text-stone-400 text-[10px] uppercase tracking-[0.3em]">
    <p>© 2026 Piano Studio Miami | Todos los derechos reservados</p>
  </footer>

</body>
</html>